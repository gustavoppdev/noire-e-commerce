// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Usuários (User)
// Base de autentificação e perfil.
model User {
  id           String    @id @db.Uuid
  name         String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  avatarUrl    String?   @db.VarChar(255)
  phone        String?   @db.VarChar(20)
  role         UserRole  @default(CUSTOMER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  addresses    Address[]
  cart         Cart[]
  orders       Order[]
  wishlist     Wishlist?
}

enum UserRole {
  CUSTOMER
  ADMIN
}

// Endereços (Address)
// Cadastro de endereços dos clientes.
// User 1:N Address
model Address {
  id            Int      @id @default(autoincrement())
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientName String?  @db.VarChar(100)
  street        String   @db.VarChar(255)
  number        String   @db.VarChar(20)
  complement    String?  @db.VarChar(100)
  neighborhood  String   @db.VarChar(255)
  city          String   @db.VarChar(100)
  state         String   @db.VarChar(2)
  zipCode       String   @db.VarChar(20)
  country       String   @default("Brazil") @db.VarChar(100)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@index([userId])
}

// Catálogo

// Produtos (Product)
// Entidade principal do catálogo.
model Product {
  id                 Int                  @id @default(autoincrement())
  price              Decimal              @db.Decimal(10, 2)
  comparePrice       Decimal?             @db.Decimal(10, 2)
  sku                String?              @unique @db.VarChar(50)
  status             ProductStatus        @default(ACTIVE)
  featured           Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  translations       ProductTranslation[]
  categoryId         Int
  category           Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brandId            Int
  brand              Brand                @relation(fields: [brandId], references: [id])
  productImages      ProductImage[]
  productVariants    ProductVariant[]
  wishlistItems      WishlistItem[]
  collectionProducts CollectionProduct[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
}

// Traduções de Produto
// Para suporte a internacionalização (ex: PT_BR, EN).
model ProductTranslation {
  id               Int     @id @default(autoincrement())
  productId        Int
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale           Locale
  name             String  @db.VarChar(100)
  slug             String  @db.VarChar(100)
  description      String  @db.Text
  shortDescription String  @db.Text

  @@unique([productId, locale])
  @@unique([locale, slug])
  @@index([productId])
}

enum Locale {
  EN
  PT_BR
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

// Categorias (Category)
// Category 1:N Products
model Category {
  id           Int                   @id @default(autoincrement())
  imageUrl     String                @db.VarChar(255)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  products     Product[]
  translations CategoryTranslation[]
}

model CategoryTranslation {
  id         Int      @id @default(autoincrement())
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     Locale
  name       String   @db.VarChar(100)
  slug       String   @db.VarChar(100)

  @@unique([categoryId, locale])
  @@unique([locale, slug])
  @@index([categoryId])
}

// Marcas (Brand)
// Brand 1:N Products
model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  slug      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

// Imagens do Produto (ProductImages)
// Product 1:N ProductImage
model ProductImage {
  id Int @id @default(autoincrement())

  productId Int
  colorId   Int?

  imageUrl String @db.VarChar(255)
  altText  String @db.VarChar(255)

  position Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color   Color?  @relation(fields: [colorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, colorId, position])
  @@index([productId])
  @@index([colorId])
}

// Variantes (ProductVariant)
// Variações de cor e tamanho do produto, controlando o estoque real.
model ProductVariant {
  id            Int        @id @default(autoincrement())
  productId     Int
  colorId       Int?
  sizeId        Int?
  stock         Int
  sku           String     @unique @db.VarChar(50)
  priceOverride Decimal?   @db.Decimal(10, 2)
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  color         Color?     @relation(fields: [colorId], references: [id])
  size          Size?      @relation(fields: [sizeId], references: [id])
  cartItems     CartItem[]

  @@unique([productId, colorId, sizeId])
  @@index([productId])
}

// Cores
model Color {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(100)
  hex             String           @db.VarChar(7)
  productVariants ProductVariant[]
  productImages   ProductImage[]
}

// Tamanhos
model Size {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(100)
  productVariants ProductVariant[]
  sortOrder       Int
}

// Carrinho

// Carrinho (Cart)
model Cart {
  id        Int        @id @default(autoincrement())
  userId    String     @db.Uuid
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@index([userId])
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

// Itens do Carrinho (CartItem)
model CartItem {
  id               Int            @id @default(autoincrement())
  cartId           Int
  productVariantId Int
  quantity         Int
  cart             Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([cartId, productVariantId])
  @@index([cartId])
}

// Pedidos (Order)
// Histórico de compras finalizadas ou pendentes.
model Order {
  id        Int         @id @default(autoincrement())
  userId    String      @db.Uuid
  addressId Int
  subtotal  Decimal     @db.Decimal(10, 2)
  shipping  Decimal     @db.Decimal(10, 2)
  total     Decimal     @db.Decimal(10, 2)
  status    OrderStatus
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  address    Address     @relation(fields: [addressId], references: [id])
  orderItems OrderItem[]

  @@index([userId])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// Itens do Pedido (OrderItem)
// Tabela imutável para histórico; salva os dados como estavam no momento da compra.
model OrderItem {
  id                 Int     @id @default(autoincrement())
  orderId            Int
  productName        String  @db.VarChar(100)
  variantDescription String  @db.VarChar(255)
  price              Decimal @db.Decimal(10, 2)
  quantity           Int
  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Wishlist (Wishlist)
// Lista de desejos do usuário (limitado a 1 por usuário).
model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    String   @unique @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wishlistItems WishlistItem[]
}

// Itens da Wishlist (WishlistItem)
model WishlistItem {
  id         Int      @id @default(autoincrement())
  wishlistId Int
  productId  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@index([productId])
}

// Coleções (Collection)
// Ex: "Summer Essentials", "Minimal Tailoring"
model Collection {
  id                 Int                     @id @default(autoincrement())
  bannerImage        String                  @db.VarChar(255)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  translations       CollectionTranslation[]
  collectionProducts CollectionProduct[]
}

model CollectionTranslation {
  id           Int        @id @default(autoincrement())
  collectionId Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  locale       Locale
  name         String     @db.VarChar(100)
  description  String     @db.Text
  slug         String     @db.VarChar(100)

  @@unique([collectionId, locale])
  @@unique([locale, slug])
  @@index([collectionId])
}

// Relação N:N entre Coleção e Produto
model CollectionProduct {
  id           Int      @id @default(autoincrement())
  collectionId Int
  productId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
}
